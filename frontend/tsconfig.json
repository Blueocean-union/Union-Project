{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@api/*": ["libs/api/*"],
      "@screens/*": ["screens/*"],
      "@components/*": ["components/*"]
    },
    "typeRoots": ["./frontend/types", "./node_modules/@types"]
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
